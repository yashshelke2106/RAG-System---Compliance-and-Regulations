# Compliance RAG runs FULLY LOCAL by default — no API keys needed.
# These variables only override defaults in src/rag/config.py.

# --- Models (Hugging Face model IDs, downloaded on first run) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
GENERATOR_MODEL=google/flan-t5-base

# --- Retrieval knobs ---
DENSE_TOP_K=20
BM25_TOP_K=20
FUSION_TOP_K=20
RERANK_TOP_K=5
# Below this reranker score the system REFUSES (says answer not in corpus).
REFUSAL_THRESHOLD=0.15

# --- Paths ---
DATA_DIR=data/raw
INDEX_DIR=storage
